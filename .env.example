# ---- GitHub ----
# Fine-grained Personal Access Token.
# Benoetigte Permissions (auf den Account/die Org begrenzt):
#   Repository: Administration (Read & Write)  -> Repos anlegen
#   Repository: Contents (Read & Write)        -> Template generate / Dateien
#   Repository: Metadata (Read)                -> Repos listen
#   Repository: Secrets (Read & Write)         -> VPS-Secrets in neue Repos schreiben
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Dein GitHub-Username ODER der Org-Name, unter dem Repos angelegt werden
GITHUB_OWNER=malte-timmermann

# true, wenn GITHUB_OWNER eine Organization ist (sonst false = User-Account)
GITHUB_OWNER_IS_ORG=false

# Nur Repos mit diesem Topic werden im Dashboard angezeigt (leer = alle)
PROJECT_TOPIC=webapp

# Template-Repo fuer "Neues Projekt" im Format owner/repo
# (muss in GitHub als "Template repository" markiert sein)
TEMPLATE_REPO=malte-timmermann/webapp-template

# ---- App ----
# Optionales Passwort fuer das Dashboard (Basic-Header). Leer = kein Schutz.
DASHBOARD_TOKEN=
HOST=127.0.0.1
PORT=8080

# ---- VPS-Deploy-Secrets ----
# Werden beim Anlegen eines neuen Projekts automatisch als Actions-Secrets
# in das neue Repo geschrieben (damit dessen deploy.yml funktioniert).
VPS_HOST=168.231.111.39
VPS_USER=projecthub
VPS_PORT=22
# Privater Deploy-SSH-Key (mehrzeilig). In .env am einfachsten als ein String
# mit \n, ODER nutze python-dotenv Multiline mit Anfuehrungszeichen:
# VPS_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n....\n-----END OPENSSH PRIVATE KEY-----\n"
VPS_SSH_KEY=

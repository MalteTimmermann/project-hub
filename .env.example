# ---- GitHub ----
# Fine-grained Personal Access Token (github.com → Settings → Developer settings → PATs)
# Benötigte Permissions:
#   Repository: Administration (Read & Write)  -> Repos anlegen
#   Repository: Contents (Read & Write)        -> Template-Dateien einspielen
#   Repository: Metadata (Read)                -> Repos listen
#   Repository: Secrets (Read & Write)         -> Actions-Secrets setzen
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# GitHub-Username oder Org-Name, unter dem neue Repos angelegt werden
GITHUB_OWNER=dein-github-username

# true, wenn GITHUB_OWNER eine Organization ist
GITHUB_OWNER_IS_ORG=false

# Nur Repos mit diesem Topic erscheinen im Dashboard (leer = alle)
PROJECT_TOPIC=webapp

# ---- App ----
# Optionales Passwort für das Dashboard (leer = kein Schutz)
DASHBOARD_TOKEN=
HOST=0.0.0.0
PORT=8080

# ---- VPS SSH ----
# User auf dem VPS, der per SSH erreichbar ist
VPS_USER=root
VPS_PORT=22
# Privater SSH-Key einzeilig mit \n statt echter Zeilenumbrüche:
# awk 'NF {printf "%s\\n", $0}' ~/.ssh/project-hub
VPS_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n....\n-----END OPENSSH PRIVATE KEY-----\n"
